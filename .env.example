ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://photo:photo@postgres:5432/photo
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=default

# Auth — CHANGE THESE before any real deployment.
ADMIN_TOKEN=dev-admin-token-change-me
SECRET_KEY=dev-secret-change-me
CLIENT_TOKEN_TTL_MINUTES=120

# Object storage — defaults to the MinIO instance included in docker-compose.
# For production, replace with real Cloudflare R2 values:
#   R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
#   R2_ACCESS_KEY_ID=<your-r2-access-key>
#   R2_SECRET_ACCESS_KEY=<your-r2-secret>
#   R2_BUCKET=photos
#   R2_PUBLIC_URL=https://<your-r2-public-or-custom-domain>
R2_ENDPOINT_URL=http://minio:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=photos
# Rewrites Docker-internal presigned URLs to localhost so the browser can reach MinIO.
R2_PUBLIC_URL=http://localhost:9000
PRESIGNED_GET_TTL=300

# Face pipeline (M5) — defaults are sane; tune per deployment.
FACE_MODEL=buffalo_l
FACE_MODEL_CACHE_DIR=/models
FACE_COSINE_THRESHOLD=0.5
FACE_SEARCH_TOP_K=20
FACE_MIN_CLUSTER_SIZE=3

# Production: GHCR image pulled by docker compose + updated by cron.
# Set to ghcr.io/<your-github-username>/<repo>:latest after pushing to GHCR.
APP_IMAGE=ghcr.io/your-github-username/photo-platform:latest

# Cloudflare Tunnel token — production only (docker compose --profile prod up).
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels.
# Routes: gallery.<domain> → http://api:8000 | grafana.<domain> → http://grafana:3000
CLOUDFLARE_TUNNEL_TOKEN=

# Grafana — production: disable anon access (Cloudflare Access handles AuthN instead).
GF_AUTH_ANONYMOUS_ENABLED=true
GF_GRAFANA_ADMIN_PASSWORD=admin
